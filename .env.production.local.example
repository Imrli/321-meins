# Kopie nach .env.production.local (liegt auf .gitignore — nicht committen).
# Vite lädt diese Datei bei `npm run build` und überschreibt damit Werte aus `.env`.
# Ohne diese Datei baut `npm run build` mit localhost → Live-Seite: "Failed to fetch" / "Load failed".

VITE_MOCK=false
VITE_SUPABASE_URL=https://<dein-projekt-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-public-key-aus-supabase-dashboard-project-settings-api>
