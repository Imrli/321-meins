# --- Lokal (npx supabase start) — in .env ---
# VITE_MOCK=false
# SUPABASE_URL=http://127.0.0.1:54321
# SUPABASE_ANON_KEY=<aus `npx supabase status`>
# MAILPIT_URL=http://localhost:8025

# --- Live / npm run build + GitHub Pages (PFLICHT) ---
# Niemals http://localhost:54321 oder 127.0.0.1 in den Produktions-Build legen — der Browser
# erreicht das nicht („Failed to fetch“, Safari: „Load failed“).
# Am einfachsten: Datei `.env.production.local` (siehe `.env.production.local.example`) mit:
VITE_MOCK=false
VITE_SUPABASE_URL=https://<dein-projekt-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-public-key-dashboard-project-settings-api>
# Nur true setzen, wenn Live-Stripe im Frontend/Backend aktiv (sonst: Testmodus-Badge & Simulation)
# VITE_STRIPE_LIVE=true
# Entweder VITE_* (empfohlen) oder gleichwertig:
# SUPABASE_URL=https://<dein-projekt-ref>.supabase.co
# SUPABASE_ANON_KEY=<anon-public-key>

# Nur lokal (Mailpit):
# MAILPIT_URL=http://localhost:8025
# Mailpit: Web-UI oft :8025, SMTP-Einlieferung typ. :1025 (von Edge aus ggf. host.docker.internal)
# MAILPIT_SMTP_HOST=127.0.0.1
# MAILPIT_SMTP_PORT=1025
# TEST_MAIL_CATCHALL=mailpit@localhost

# QR-E-Mail nach Auftragserteilung (Edge Function `auftrag-qr-email` via `supabase functions serve` / deploy)
# A) Resend (Produktion)
# RESEND_API_KEY=
# RESEND_FROM=321 meins <deine-domain@resend.dev>
# B) SMTP / Mailpit (lokal: typ. Port 1025; von der Edge-Runtime aus ggf. host.docker.internal)
# QR_EMAIL_SMTP_HOST=host.docker.internal
# QR_EMAIL_SMTP_PORT=1025
# QR_EMAIL_FROM=321 meins <noreply@321-meins.local>

# Transporteur-E-Mails (Edge: `transporteur-registration-emails`, `transporteur-verifiziert-email`)
# Infomaniak SMTP; in Produktion: `supabase secrets set INFOMANIAK_SMTP_PASS=...` (nicht ins Repo committen).
# INFOMANIAK_SMTP_PASS=
# Ohne Passwort oder mit VITE_MOCK=true: Functions loggen nur, kein Versand.

# Öffentliche URL der SPA (Stripe Checkout success/cancel)
# FRONTEND_URL=http://127.0.0.1:5173

# GitHub Actions: dieselben Werte als Repository-Secrets VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY
# (Workflow `.github/workflows/pages.yml`).

# Startseiten-Auktions-Slider: automatischer Wechsel in Millisekunden (mind. 5000, Standard 30000)
# VITE_HOME_AUCTION_SLIDER_INTERVAL_MS=30000
