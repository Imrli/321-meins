# Schritt 2: Werte aus `npx supabase status` (nach `npx supabase start`)
VITE_MOCK=false
# Nur true setzen, wenn Live-Stripe im Frontend/Backend aktiv (sonst: Testmodus-Badge & Simulation)
# VITE_STRIPE_LIVE=true
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=
MAILPIT_URL=http://localhost:8025
# Mailpit: Web-UI oft :8025, SMTP-Einlieferung typ. :1025 (von Edge aus ggf. host.docker.internal)
# MAILPIT_SMTP_HOST=127.0.0.1
# MAILPIT_SMTP_PORT=1025
# TEST_MAIL_CATCHALL=mailpit@localhost

# QR-E-Mail nach Auftragserteilung (Edge Function `auftrag-qr-email` via `supabase functions serve` / deploy)
# A) Resend (Produktion)
# RESEND_API_KEY=
# RESEND_FROM=321 meins <deine-domain@resend.dev>
# B) SMTP / Mailpit (lokal: typ. Port 1025; von der Edge-Runtime aus ggf. host.docker.internal)
# QR_EMAIL_SMTP_HOST=host.docker.internal
# QR_EMAIL_SMTP_PORT=1025
# QR_EMAIL_FROM=321 meins <noreply@321-meins.local>

# Öffentliche URL der SPA (Stripe Checkout success/cancel)
# FRONTEND_URL=http://127.0.0.1:5173
# VITE_SUPABASE_URL=http://localhost:54321
# VITE_SUPABASE_ANON_KEY=

# Startseiten-Auktions-Slider: automatischer Wechsel in Millisekunden (mind. 5000, Standard 30000)
# VITE_HOME_AUCTION_SLIDER_INTERVAL_MS=30000
